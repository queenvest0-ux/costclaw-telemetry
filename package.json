{
  "name": "costclaw",
  "version": "0.1.0",
  "description": "Real-time LLM cost tracking and local dashboard for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "openclaw",
    "llm",
    "cost",
    "telemetry",
    "dashboard"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Aperturesurvivor/costclaw-telemetry#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aperturesurvivor/costclaw-telemetry.git"
  },
  "bugs": {
    "url": "https://github.com/Aperturesurvivor/costclaw-telemetry/issues"
  }
}
